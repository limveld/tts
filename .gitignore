*.wav
.idea
.DS_Store
/.venv/
/bin/
mise.local.toml
/raw/

# Downloaded soundboard clips (third-party audio); the mapping lives in sfx.toml
# and `mise run sfx:fetch` re-downloads them.
/sfx/*
!/sfx/.gitkeep

# Bot OAuth tokens (secret/state written by `mise run bot:auth`).
/bot.tokens.json

# Bot SQLite database (custom commands, points) + WAL sidecars.
/bot.db
/bot.db-shm
/bot.db-wal
