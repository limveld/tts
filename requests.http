###############################################################################
# Validation & limits
###############################################################################

### Empty text is rejected with 400
# @name say-empty
POST {{baseUrl}}/say
Content-Type: application/json

{
  "text": "   "
}

> {%
    client.test("rejected (400)", () => client.assert(response.status === 400));
    client.test("error mentions text", () => client.assert(response.body.error === "text is required"));
%}

### Over-long text is truncated to -max-chars (default 500), not rejected
# @name say-long
POST {{baseUrl}}/say
Content-Type: application/json

{
  "text": "This message is intentionally very long so that it exceeds the maximum character limit configured on the server. Twitch messages can be lengthy, and instead of dropping the request the server truncates the text down to the configured cap and still speaks the beginning of it. Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur."
}

> {%
    client.test("accepted (202)", () => client.assert(response.status === 202));
    client.test("was truncated", () => client.assert(response.body.truncated === true));
%}

###############################################################################
# Queue controls
###############################################################################
# Tip to see queueing without audio: run "pause" first, then the three "burst"
# requests below, then "status" (they pile up), then "clear" (drops them) — or
# "resume" to actually play them.

### Pause — stop starting new items (a clip already playing finishes)
# @name pause
POST {{baseUrl}}/pause

> {%
    client.test("200 OK", () => client.assert(response.status === 200));
    client.test("paused is true", () => client.assert(response.body.paused === true));
%}

### Burst 1 of 3 (queues; only plays when not paused)
# @name burst-1
POST {{baseUrl}}/say
Content-Type: application/json

{ "text": "First message in the queue." }

### Burst 2 of 3
# @name burst-2
POST {{baseUrl}}/say
Content-Type: application/json

{ "text": "Second message in the queue." }

### Burst 3 of 3
# @name burst-3
POST {{baseUrl}}/say
Content-Type: application/json

{ "text": "Third message in the queue." }

### Resume — start playing queued items again (serially, one at a time)
# @name resume
POST {{baseUrl}}/resume

> {%
    client.test("200 OK", () => client.assert(response.status === 200));
    client.test("paused is false", () => client.assert(response.body.paused === false));
%}

### Clear — drop all pending items (the current clip keeps playing)
# @name clear
POST {{baseUrl}}/clear

> {%
    client.test("200 OK", () => client.assert(response.status === 200));
    client.test("reports how many were cleared", () => client.assert(typeof response.body.cleared === "number"));
    client.log("cleared " + response.body.cleared + " item(s)");
%}

### Skip — stop the current clip (synth or playback) and advance to the next
# @name skip
POST {{baseUrl}}/skip

> {%
    client.test("200 OK", () => client.assert(response.status === 200));
    client.test("reports whether something was skipped", () => client.assert(typeof response.body.skipped === "boolean"));
%}

###############################################################################
# Auth (only when the server is started with -token / TTS_TOKEN)
###############################################################################

### Missing token -> 401 (start the server with `-token changeme` to see this)
# @name auth-missing
GET {{baseUrl}}/status

> {%
    // With a token-protected server this is 401; with an open server it's 200.
    client.log("status without token = " + response.status);
%}

### Correct token via Authorization: Bearer
# @name auth-bearer
POST {{baseUrl}}/say
Authorization: Bearer {{token}}
Content-Type: application/json

{ "text": "Authenticated request using a bearer token." }

> {%
    client.test("authorized (202)", () => client.assert(response.status === 202));
%}

### Correct token via the X-TTS-Token header (alternative)
# @name auth-header
GET {{baseUrl}}/status
X-TTS-Token: {{token}}

###############################################################################
# Method enforcement
###############################################################################

### GET on a POST-only route -> 405
# @name wrong-method
GET {{baseUrl}}/say

> {%
    client.test("method not allowed (405)", () => client.assert(response.status === 405));
%}
