### TTS server — usage examples & tests
#
# Format: JetBrains HTTP Client (GoLand/IntelliJ). The `> {% ... %}` blocks are
# response-handler tests; the plain requests also work in the VS Code REST Client.
#
# Prerequisites:
#   mise run serve            # or: mise run service:install
# The server binds 127.0.0.1:8080 by default. The FIRST /say blocks until the
# Kokoro model finishes loading (and, on a cold machine, downloads ~330 MB once),
# so give it a few seconds. Successful /say requests PLAY AUDIO out loud via VLC.
#
# Variables (edit inline, or override with an http-client.env.json):
@baseUrl = http://127.0.0.1:8080
# Only needed if the server was started with -token / TTS_TOKEN:
@token = changeme

###############################################################################
# Health & status
###############################################################################

### Liveness check (no auth, even when a token is configured)
# @name health
GET {{baseUrl}}/healthz

> {%
    client.test("200 OK", () => client.assert(response.status === 200));
    client.test("status is ok", () => client.assert(response.body.status === "ok"));
%}

### Queue + engine status
# @name status
GET {{baseUrl}}/status

> {%
    client.test("200 OK", () => client.assert(response.status === 200));
    client.test("has queue fields", () => {
        client.assert(response.body.hasOwnProperty("paused"));
        client.assert(response.body.hasOwnProperty("engineReady"));
        client.assert(response.body.hasOwnProperty("queueLength"));
    });
    client.log("engineReady = " + response.body.engineReady +
               ", queueLength = " + response.body.queueLength);
%}

###############################################################################
# Speaking — the endpoint your Twitch bot calls
###############################################################################

### Basic: speak some text (JSON body). Plays audio on success.
# @name say
POST {{baseUrl}}/say
Content-Type: application/json

{
  "text": "Hello chat, this is the text to speech bot."
}

> {%
    client.test("accepted (202)", () => client.assert(response.status === 202));
    client.test("returns an id and position", () => {
        client.assert(typeof response.body.id === "number");
        client.assert(typeof response.body.position === "number");
    });
    // Remember the id for later requests if you want to reference it.
    client.global.set("lastJobId", response.body.id);
    client.log("queued job #" + response.body.id + " at position " + response.body.position);
%}

### Per-request voice override — American male "Adam"
# @name say-voice-adam
POST {{baseUrl}}/say
Content-Type: application/json

{
  "text": "This clip is spoken by Adam instead of the default voice.",
  "voice": "am_adam"
}

> {%
    client.test("accepted (202)", () => client.assert(response.status === 202));
%}

### Another voice — British female "Emma"
# @name say-voice-emma
POST {{baseUrl}}/say
Content-Type: application/json

{
  "text": "And this one is Emma, a British English voice.",
  "voice": "bf_emma"
}

### Form-encoded body (handy for shells / simple bots)
# @name say-form
POST {{baseUrl}}/say
Content-Type: application/x-www-form-urlencoded

text=Speaking from a form encoded request&voice=af_bella

> {%
    client.test("accepted (202)", () => client.assert(response.status === 202));
%}

### Query-string form (text as a URL parameter)
# @name say-query
POST {{baseUrl}}/say?text=Speaking%20from%20a%20query%20parameter&voice=am_michael

> {%
    client.test("accepted (202)", () => client.assert(response.status === 202));
%}

###############################################################################
# All kokoro voices — one request each (the text names the voice so you can
# tell them apart by ear). Source: kokoro/demo/app.py CHOICES.
#
# Tip: run "pause" (below) first, fire the voices you want to compare, then
# "resume" so they play back-to-back instead of piling onto the speakers.
#
# British (b*) voices work fine against the default `-lang a` server — they use
# American pronunciation with that speaker's timbre (kokoro just logs a mismatch
# warning). For true British G2P, start the server with `-lang b`.
#
# Non-English voices (Spanish ef_/em_, French ff_, Hindi hf_/hm_, Italian
# if_/im_, Portuguese pf_/pm_, Japanese jf_/jm_, Chinese zf_/zm_) require the
# server started with the matching `-lang <code>` and the extra misaki language
# packages, so they aren't listed as live requests here.
###############################################################################

# ---- American English · female (lang a) -------------------------------------

### af_heart (default)
POST {{baseUrl}}/say
Content-Type: application/json

{ "text": "This is the af heart voice.", "voice": "af_heart" }

### af_bella
POST {{baseUrl}}/say
Content-Type: application/json

{ "text": "This is the af bella voice.", "voice": "af_bella" }

### af_nicole
POST {{baseUrl}}/say
Content-Type: application/json

{ "text": "let's fucking goon", "voice": "af_nicole" }

